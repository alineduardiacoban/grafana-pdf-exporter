# ─────────────────────────────────────────────────────────────────
#  Grafana PDF Exporter — configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Use a Grafana Service Account token instead of username/password:
#   GRAFANA_SERVICE_ACCOUNT=true
#   GRAFANA_PASSWORD=glsa_xxxxxxxxxxxxxxxxxxxx
GRAFANA_SERVICE_ACCOUNT=false

# ── Browser ───────────────────────────────────────────────────────
# Leave unset to use Puppeteer's bundled Chromium (downloaded automatically).
# Set to use a system-installed browser instead (saves ~300 MB):
#   CHROMIUM_PATH=/usr/bin/chromium          # AlmaLinux / RHEL
#   CHROMIUM_PATH=/usr/bin/chromium-browser  # Debian / Ubuntu
#   CHROMIUM_PATH=/usr/bin/google-chrome     # Google Chrome
# CHROMIUM_PATH=

# ── PDF output ────────────────────────────────────────────────────
PDF_WIDTH_PX=1920
PDF_HEIGHT_PX=auto

# ── Dashboard behaviour ───────────────────────────────────────────
FORCE_KIOSK_MODE=true
HIDE_DASHBOARD_CONTROLS=true
EXPAND_COLLAPSED_PANELS=true
EXPAND_TABLE_PANELS=true

# ── Timeouts ──────────────────────────────────────────────────────
NAVIGATION_TIMEOUT=60000

CHECK_QUERIES_TO_COMPLETE=false
CHECK_QUERIES_TO_COMPLETE_QUERIES_INTERVAL=1000
CHECK_QUERIES_TO_COMPLETE_QUERIES_COMPLETION_TIMEOUT=60000

# ── Smart filename (optional) ─────────────────────────────────────
EXTRACT_DATE_AND_DASHBOARD_NAME_FROM_HTML_PANEL_ELEMENTS=false

# ── Server ────────────────────────────────────────────────────────
PORT=3001

# ── Debug ─────────────────────────────────────────────────────────
DEBUG_MODE=false
